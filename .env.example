# Cloud sync (Firebase) is entirely optional. Leave these unset and the app
# keeps working exactly as before: local-only, no login, data in this
# browser's localStorage.
#
# To enable shared trips synced across devices/people:
#   1. Create a free project at https://console.firebase.google.com
#   2. Authentication > Sign-in method > enable "Email/Password"
#   3. Firestore Database > Create database (production mode)
#   4. Firestore Database > Rules > paste the contents of firestore.rules
#      from this repo and publish
#   5. Project settings > General > Your apps > add a Web app > copy the
#      config values below
#   6. Fill in all four values, then `npm run dev` / `npm run build`
#   7. For the deployed (GitHub Pages) build, add the same four values as
#      repository secrets (Settings > Secrets and variables > Actions)
#      with these exact names, so the deploy workflow can inject them.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
